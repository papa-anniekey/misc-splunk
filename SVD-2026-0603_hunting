index=_internal
(
    sourcetype=splunkd_access
    OR source="*splunkd_access.log*"
    OR sourcetype=splunk_web_access
    OR source="*web_access.log*"
)
(
    "__raw/v1/postgres"
    OR "/splunkd/__raw/v1/postgres"
    OR "postgres/recovery"
    OR "postgres/recovery/restore"
)
| rex field=_raw "(?<http_method>GET|POST|PUT|DELETE|PATCH|OPTIONS)\s+(?<http_uri>/\S+)"
| eval method=coalesce(method, http_method)
| eval uri=coalesce(uri, uri_path, request, http_uri)
| eval src=coalesce(clientip, src, ip, remote_addr)
| eval dest=host
| where method="POST"
| where like(uri, "%__raw/v1/postgres%")
    OR like(uri, "%postgres/recovery%")
| eval signature=case(
    like(uri, "%postgres/recovery/restore%"), "Suspicious Splunk Postgres Recovery Restore API Request",
    like(uri, "%__raw/v1/postgres%"), "Suspicious Splunk Raw Postgres API Request",
    true(), "Suspicious Splunk Postgres API Request"
)
| eval severity=case(
    like(uri, "%postgres/recovery/restore%"), "critical",
    true(), "high"
)
| table _time signature severity src dest user method uri status source sourcetype _raw
| sort - _time














